# Copy this file to .env (which is gitignored) and fill in what you need.
# Every variable here is OPTIONAL — the framework still works without them,
# with the noted limitations.

# Required only for the UI's "Generate & Run" button.
# Get a key at https://console.anthropic.com (new accounts get $5 free credit).
ANTHROPIC_API_KEY=

# Override the UI port (default: 3001).
# UI_PORT=3002

# Per-feature credentials referenced by generated tests via process.env fallbacks.
# Example pattern — add your own per-feature pairs:
# APP_VERIFIED_EMAIL=
# APP_VERIFIED_PASSWORD=
