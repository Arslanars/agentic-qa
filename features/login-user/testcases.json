        "Click 'Sign In'"
      ],
      "testData": "Email: no-such-user-<ts>@example.com\nPassword: AnyPass!1234",
      "expectedResult": "Auth API returns non-2xx; URL stays on /login",
      "postCondition": "User NOT authenticated",
      "linkedSpec": ".features-gen/features/login-user/login.feature.spec.js",
      "linkedTestTitle": "AC1-NEG-02 — non-existent email is rejected"
    },
