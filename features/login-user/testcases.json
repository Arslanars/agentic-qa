{
  "feature": "login-user",
  "storyId": "Login",
  "storyTitle": "Login User",
  "applicationUrl": "https://moontower.aiimone.com/Login",
  "testCases": [
    {
      "id": "Login-AC1-POS-01",
      "scenario": "AC1: Visit site and try to login — POSITIVE",
      "testCase": "Sign in with valid credentials and land on /select-location",
      "preCondition": "Browser open at /Login; user account 'developers@moontower.com' exists; Email + Password fields and Sign In button visible",
      "testSteps": [
        "Navigate to /Login",
        "Enter 'developers@moontower.com' into the Email field",
        "Enter '12345678' into the Password field",
        "Click 'Sign In'"
      ],
      "testData": "Email: developers@moontower.com\nPassword: 12345678",
      "expectedResult": "Redirect to /select-location with 'Select Your Location' heading and 'Restaurant: …' paragraph",
      "postCondition": "User authenticated; session cookie set",
      "linkedSpec": ".features-gen/features/login-user/login.feature.spec.js",
      "linkedTestTitle": "AC1-POS-01 — successful login with valid credentials"
    },
    {
      "id": "Login-AC1-NEG-01",
      "scenario": "AC1: NEGATIVE — wrong password",
      "testCase": "Sign in with valid email but wrong password",
      "preCondition": "Browser open at /Login",
      "testSteps": [
        "Enter 'developers@moontower.com' in Email",
        "Enter a deliberately wrong password",
        "Click 'Sign In'"
      ],
      "testData": "Email: developers@moontower.com\nPassword: WrongPassword!2025",
      "expectedResult": "Auth API returns non-2xx; URL stays on /login",
      "postCondition": "User NOT authenticated",
      "linkedSpec": ".features-gen/features/login-user/login.feature.spec.js",
      "linkedTestTitle": "AC1-NEG-01 — wrong password is rejected"
    },
    {
